{
  "name": "bad-artists-club",
  "version": "1.0.0",
  "description": "Multiplayer drawing guessing game",
  "private": true,
  "workspaces": [
    "apps/web",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=apps/web\" \"npm run dev --workspace=server\"",
    "build": "npm run build --workspace=apps/web && npm run build --workspace=server",
    "start": "npm run start --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "typescript": "^5.3.3"
  }
}
